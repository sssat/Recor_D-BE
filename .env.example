DEBUG=True
SECRET_KEY=your-secret-key-here

# Database (production only, 로컬은 SQLite 자동 사용)
# Cloudtype MySQL: 서비스 연결 후 대시보드에서 확인
DATABASE_URL=postgres://user:password@host:5432/record_db

# 배포 도메인 (Cloudtype이 발급한 도메인, 쉼표로 여러 개 가능)
ALLOWED_HOSTS=xxx.cloudtype.app

# Google AI Studio (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# OpenAI STT (회의록 음성 업로드)
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Kakao (https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키)
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000